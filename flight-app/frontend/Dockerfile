FROM node:18-alpine

WORKDIR /app

# Next.js embeds NEXT_PUBLIC_* at build-time, so accept build args
# and export them as ENV before `npm run build`.
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_PROCESSING_TIMEOUT_MS
ARG NEXT_PUBLIC_RESULT_WAIT_MS
ARG NEXT_PUBLIC_CHART_WAIT_MS

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_PROCESSING_TIMEOUT_MS=${NEXT_PUBLIC_PROCESSING_TIMEOUT_MS}
ENV NEXT_PUBLIC_RESULT_WAIT_MS=${NEXT_PUBLIC_RESULT_WAIT_MS}
ENV NEXT_PUBLIC_CHART_WAIT_MS=${NEXT_PUBLIC_CHART_WAIT_MS}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
